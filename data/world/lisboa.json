  "dialogues": [
    {
      "id": "merchant_offer",
      "speaker": "Rodrigo",
      "text": "Rapaz, preciso de maos rapidas. Roubaram-me uma caixa nas vielas do cais. Se ma trouxeres inteira, pago-vos com prata e boa memoria.",
      "primary_label": "Aceitar trabalho",
      "secondary_label": "Fechar",
      "actions": [
        {
          "type": "start_quest",
          "quest_id": "sq_001_a_caixa_perdida"
        }
      ]
    },
    {
      "id": "merchant_active",
      "speaker": "Rodrigo",
      "text": "Ainda nao tendes a minha caixa. Os ladrões meteram-se pela viela do cais; depressa, antes que vendam o que nao lhes pertence.",
      "secondary_label": "Prosseguir"
    },
    {
      "id": "merchant_reward",
      "speaker": "Rodrigo",
      "text": "A caixa voltou inteira. Fizestes mais do que muitos guardas fariam por menos oiro. Toma a vossa paga e este anel; entre mercadores, uma mao firme vale muito.",
      "primary_label": "Receber recompensa",
      "secondary_label": "Fechar",
      "actions": [
        {
          "type": "complete_quest",
          "quest_id": "sq_001_a_caixa_perdida"
        }
      ]
    },
    {
      "id": "merchant_done",
      "speaker": "Rodrigo",
      "text": "Se voltar a perder mercadoria, espero que estejais por perto. Lisboa tem poucos homens discretos e menos ainda com palavra.",
      "secondary_label": "Prosseguir"
    },
    {
      "id": "chapel_arrive",
      "speaker": "Capela do Porto",
      "text": "As velas ardem baixas e o sal pega-se a pedra antiga. A capela espera, silenciosa, como se ainda houvesse algo por cumprir no cais.",
      "secondary_label": "Prosseguir"
    },
    {
      "id": "chapel_joao",
      "speaker": "Capela do Porto",
      "text": "Uma figura espera junto ao altar, meio sombra, meio maruja. O ar dentro da capela parece mais pesado do que la fora.",
      "primary_label": "Entrar",
      "secondary_label": "Fechar",
      "actions": [
        {
          "type": "start_cutscene",
          "cutscene_id": "cs_010_meet_joao"
        }
      ]
    },
    {
      "id": "dock_alley_search",
      "speaker": "Viela do Cais",
      "text": "As caixas empilham-se contra os muros e ha pegadas frescas entre o lodo e a palha. Alguem vos viu chegar e nao gostou disso.",
      "primary_label": "Avancar",
      "secondary_label": "Fechar",
      "actions": [
        {
          "type": "start_battle",
          "battle_id": "battle_lost_crate_thieves"
        }
      ]
    },
    {
      "id": "warehouse_entry",
      "speaker": "Armazem Regio",
      "text": "O fumo sobe por cima dos telhados e sinos batem a rebate. Homens correm, gritos cruzam o cais e o ar sabe a madeira queimada.",
      "primary_label": "Correr ao armazem",
      "secondary_label": "Fechar",
      "actions": [
        {
          "type": "start_cutscene",
          "cutscene_id": "cs_020_alarm_bells"
        }
      ]
    },
    {
      "id": "captain_entry",
      "speaker": "Patio da Ordem",
      "text": "Soldados abrem espaco, mas nao por respeito. No alto do patio, o capitao Lourenco espera como juiz e carrasco na mesma postura.",
      "primary_label": "Confrontar",
      "secondary_label": "Fechar",
      "actions": [
        {
          "type": "start_cutscene",
          "cutscene_id": "cs_040_captain_confrontation"
        }
      ]
    },
    {
      "id": "north_road_hint",
      "speaker": "Estrada do Norte",
      "text": "A estrada sobe para fora da cidade. Para ja, o vosso rumo ainda se decide entre o cais, a ordem e os ecos do que ardeu em Lisboa.",
      "secondary_label": "Prosseguir"
    },
    {
      "id": "north_road_depart",
      "speaker": "Estrada do Norte",
      "text": "A cidade fica para tras mal se passa o arco. Joao espera ao amanhecer, e a estrada para Tomar ja nao parece promessa, mas destino.",
      "primary_label": "Partir",
      "secondary_label": "Fechar",
      "actions": [
        {
          "type": "start_cutscene",
          "cutscene_id": "cs_050_departure_sunrise"
        }
      ]
    },
    {
      "id": "north_road_done",
      "speaker": "Estrada do Norte",
      "text": "Tomar esta finalmente ao vosso alcance. Quando quiserdes seguir, basta abrir a carta do reino e escolher o rumo.",
      "primary_label": "Abrir mapa",
      "secondary_label": "Ficar em Lisboa",
      "actions": [
        {
          "type": "open_overworld_map"
        }
      ]
    }
  ],
